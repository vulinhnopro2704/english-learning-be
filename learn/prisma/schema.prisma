generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Course {
  id          Int                  @id @default(autoincrement())
  title       String               @db.VarChar(255)
  enTitle     String?              @db.VarChar(255)
  description String?
  image       String?              @db.VarChar(255)
  createdAt   DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime             @updatedAt @db.Timestamptz(6)
  icon        String?              @db.VarChar(10)
  isPublished Boolean              @default(false)
  isUserCreated Boolean            @default(false)
  createdByUserId String?          @db.Uuid
  order       Int                  @default(0)
  lessons     Lesson[]
  progress    UserCourseProgress[]

  @@index([createdByUserId])
  @@index([isUserCreated, createdByUserId])
}

model Lesson {
  id          Int                  @id @default(autoincrement())
  title       String               @db.VarChar(255)
  description String?
  image       String?              @db.VarChar(255)
  createdAt   DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime             @updatedAt @db.Timestamptz(6)
  courseId    Int?
  isPublished Boolean              @default(false)
  isUserCreated Boolean            @default(false)
  createdByUserId String?          @db.Uuid
  order       Int                  @default(0)
  course      Course?              @relation(fields: [courseId], references: [id])
  progress    UserLessonProgress[]
  words       Word[]
  sessions    PracticeSession[]

  @@index([courseId])
  @@index([createdByUserId])
  @@index([isUserCreated, createdByUserId])
}

model Word {
  id              Int                  @id @default(autoincrement())
  word            String               @db.VarChar(255)
  pronunciation   String?              @db.VarChar(255)
  phoneticUs      String?              @db.VarChar(255)
  phoneticUk      String?              @db.VarChar(255)
  meaning         String
  example         String?
  exampleVi       String?
  image           String?              @db.VarChar(255)
  audio           String?              @db.VarChar(255)
  audioUs         String?              @db.VarChar(255)
  audioUk         String?              @db.VarChar(255)
  audioUsFileId   String?              @db.Uuid
  audioUkFileId   String?              @db.Uuid
  dictionaryMetadata Json?
  createdAt       DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime             @updatedAt @db.Timestamptz(6)
  lessonId        Int?
  pos             String?              @db.VarChar(255)
  cefr            String?              @db.VarChar(10)
  vocabularyNotes UserVocabularyNote[]
  progress        UserWordProgress[]
  examples        WordExample[]
  lesson          Lesson?              @relation(fields: [lessonId], references: [id])

  @@index([lessonId])
}

model WordExample {
  id          Int      @id @default(autoincrement())
  wordId      Int
  example     String
  exampleVi   String?
  exampleAudio String? @db.VarChar(255)
  order       Int      @default(0)
  source      Json?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)
  word        Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@index([wordId])
  @@index([wordId, order])
  @@unique([wordId, example])
}

model UserStreak {
  userId        String   @id @db.Uuid
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastActivity  DateTime @db.Timestamptz(6)
}

model UserCourseProgress {
  id             Int      @id @default(autoincrement())
  userId         String   @db.Uuid
  courseId       Int
  isCompleted    Boolean  @default(false)
  startedAt      DateTime @default(now()) @db.Timestamptz(6)
  lastAccessedAt DateTime @updatedAt @db.Timestamptz(6)
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
}

model UserLessonProgress {
  id          Int          @id @default(autoincrement())
  userId      String       @db.Uuid
  lessonId    Int
  status      LessonStatus @default(LOCKED)
  score       Int          @default(0)
  completedAt DateTime?    @db.Timestamptz(6)
  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model UserWordProgress {
  id             Int              @id @default(autoincrement())
  userId         String           @db.Uuid
  wordId         Int
  status         WordMasteryLevel @default(NEW)
  proficiency    Int              @default(0)
  nextReview     DateTime?        @db.Timestamptz(6)
  lastReviewedAt DateTime?        @db.Timestamptz(6)
  reviewCount    Int              @default(0)
  correctCount   Int              @default(0)
  state          Int              @default(0)
  difficulty     Float            @default(0)
  stability      Float            @default(0)
  interval       Int              @default(0)
  reps           Int              @default(0)
  lapses         Int              @default(0)
  word           Word             @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@index([userId])
  @@index([nextReview])
  @@index([userId, status])
}

model UserVocabularyNote {
  id            Int      @id @default(autoincrement())
  userId        String   @db.Uuid
  wordId        Int
  note          String?
  isFavorite    Boolean  @default(false)
  customExample String?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)
  word          Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@index([userId])
}

enum LessonStatus {
  LOCKED
  UNLOCKED
  IN_PROGRESS
  COMPLETED
}

enum WordMasteryLevel {
  NEW
  LEVEL_1
  LEVEL_2
  LEVEL_3
  LEVEL_4
  LEVEL_5
}

enum PracticeType {
  FSRS // Ôn tập (Review) — spaced repetition
  LEARN_LESSON // Học mới (Learn) — lesson-based
  DICTIONARY_SAVE // Lưu từ từ từ điển và kích hoạt học
}

model PracticeSession {
  id              Int          @id @default(autoincrement())
  userId          String       @db.Uuid
  type            PracticeType
  lessonId        Int?
  totalWords      Int          @default(0)
  correctCount    Int          @default(0)
  totalDurationMs Int          @default(0)
  startedAt       DateTime     @default(now()) @db.Timestamptz(6)
  completedAt     DateTime?    @db.Timestamptz(6)
  lesson          Lesson?      @relation(fields: [lessonId], references: [id])

  @@index([userId])
  @@index([userId, type])
}
