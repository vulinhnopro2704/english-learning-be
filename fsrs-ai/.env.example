# FSRS-AI local/dev environment
# Copy to fsrs-ai/.env and adjust values.

# Required
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/fsrs_ai"

# Service
PORT=8000
ROOT_PATH=

# Optimizer policy
FSRS_TRAIN_MIN_VALID_LOGS=50
FSRS_TRAIN_MIN_DAYS_SINCE_LAST=3
FSRS_TRAIN_MIN_IMPROVEMENT_PCT=0.02
FSRS_TRAIN_METRIC=log_loss

# Reschedule safety
FSRS_RESCHEDULE_MAX_SHIFT_RATIO=0.3
FSRS_ASYNC_RESCHEDULE_ENABLED=true
