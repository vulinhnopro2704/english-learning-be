PORT=3003
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/english_learning
CORS_ORIGIN=http://localhost:3001

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SWAGGER_ENABLED=true
SWAGGER_PATH=api-docs
SWAGGER_TITLE=Storage API

LOGGER_LEVEL=info
LOGGER_DIR=logs
LOGGER_FILENAME=app-%DATE%.log
LOGGER_MAX_SIZE=10m
LOGGER_MAX_FILES=14d
LOGGER_BODY_MAX=0

SIGNED_URL_TTL_SECONDS=300
MAX_FILE_SIZE_MB=10
ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,video/mp4,application/pdf
