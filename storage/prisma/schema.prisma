generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum FileType {
  IMAGE
  VIDEO
  FILE
}

model File {
  id        String   @id @default(uuid()) @db.Uuid
  publicId  String   @unique @map("public_id") @db.VarChar(255)
  secureUrl String   @map("secure_url") @db.Text
  type      FileType
  format    String?  @db.VarChar(20)
  size      Int
  ownerId   String   @map("owner_id") @db.Uuid
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([ownerId, createdAt(sort: Desc)], map: "idx_files_owner_created")
  @@index([type, createdAt(sort: Desc)], map: "idx_files_type_created")
  @@map("files")
}
